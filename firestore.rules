rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function userRole() {
      return signedIn() && userDoc(request.auth.uid) != null
        ? userDoc(request.auth.uid).data.role
        : 'viewer';
    }

    function isAdmin() {
      return userRole() == 'admin';
    }

    function isEditorOrAdmin() {
      return userRole() == 'admin' || userRole() == 'editor';
    }

    // Releases
    match /releases/{releaseId} {
      allow read: if true;
      allow create: if signedIn() && isEditorOrAdmin();
      allow update: if signedIn() && isEditorOrAdmin();
      allow delete: if signedIn() && isAdmin();
    }

    // Activity logs (write when actions happen)
    match /activityLogs/{logId} {
      allow read: if true;
      allow create: if signedIn() && isEditorOrAdmin();
      allow update, delete: if false;
    }

    // Comments (only author can edit/delete)
    match /releaseComments/{commentId} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if signedIn() && resource.data.userEmail == request.auth.token.email;
    }

    // Users RBAC profiles
    match /users/{uid} {
      allow read: if signedIn();
      // Allow user to create their own profile (client bootstrap)
      allow create: if signedIn() && request.auth.uid == uid;
      // Allow user to update non-role fields in their own doc
      allow update: if signedIn() && request.auth.uid == uid
        && !(request.resource.data.diff(resource.data).changedKeys().hasAny(['role']));
      // Admin can update roles and manage any profile
      allow update: if signedIn() && isAdmin();
      allow delete: if false;
    }

    // Access requests - anyone signed in can create, admin can read/update/delete
    match /accessRequests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.token.email != null;
      allow delete: if request.auth != null;
    }

    // Notifications - user can read their own, admin can read all
    match /notifications/{notificationId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.uid || request.auth.uid == resource.data.uid);
      allow create: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // App config (teams groups) - read by all signed in, write by admin only
    match /appConfig/{configId} {
      allow read: if signedIn();
      allow write: if signedIn() && isAdmin();
    }
  }
}
